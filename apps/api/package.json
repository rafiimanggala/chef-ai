    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@chef-ai/shared": "workspace:*",
    "better-auth": "^1.2.0",
    "drizzle-orm": "^0.40.0",
    "hono": "^4.7.0",
    "ioredis": "^5.6.0",
    "postgres": "^3.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
